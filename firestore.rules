// Reglas compartidas para Testimonio Vivo y Angelicas Connections
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 👤 Perfiles de usuario (Testimonio Vivo)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 📖 Testimonios (Testimonio Vivo)
    match /testimonios/{testimonioId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.authorUid == request.auth.uid;
    }

    // 💬 Salas de Chat (Testimonio Vivo)
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }

      match /candidates/{candidateId} {
        allow read, write: if request.auth != null;
      }
    }

    // 📡 Chats Legacy
    match /chats/{messageId} {
      allow read, write: if request.auth != null;
    }

    // 💎 Planes de Suscripción
    match /plans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    // 💰 Donaciones
    match /donations/{donationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // 🌟 Angelicas Connections (colección nueva)
    match /connections/{userId}/{doc=**} {
      // Cada usuario solo accede a su propia subcolección
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

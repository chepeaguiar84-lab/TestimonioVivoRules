// Reglas públicas de Testimonio Vivo + Angelicas Connections
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // 🎤 Fotos y audios de Testimonios (Testimonio Vivo)
    match /testimonios/{testimonioId}/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.size < 10 * 1024 * 1024; // límite 10 MB
      allow delete: if request.auth != null;
    }

    // 👤 Foto de perfil del usuario (Testimonio Vivo)
    match /users/{userId}/profile.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 💬 Multimedia de Chats (Testimonio Vivo)
    match /chats/{chatId}/{fileName} {
      allow read, write: if request.auth != null 
                         && request.resource.size < 15 * 1024 * 1024;
    }

    // 🌟 Angelicas Connections (colección nueva en Storage)
    match /connections/{userId}/{fileName} {
      // Lectura solo para autenticados
      allow read: if request.auth != null;

      // Subida limitada a 10 MB, igual que Testimonio Vivo
      allow create: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.size < 10 * 1024 * 1024;

      // Eliminación permitida solo al dueño
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
